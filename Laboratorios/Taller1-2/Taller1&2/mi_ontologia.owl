<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://test.org/onto.owl"
         xmlns="http://test.org/onto.owl#">

<owl:Ontology rdf:about="http://test.org/onto.owl"/>

<owl:DatatypeProperty rdf:about="#puede">
  <rdfs:domain rdf:resource="#Animal"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#Animal">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Mamifero">
  <rdfs:subClassOf rdf:resource="#Animal"/>
</owl:Class>

<owl:Class rdf:about="#Ave">
  <rdfs:subClassOf rdf:resource="#Animal"/>
</owl:Class>

<owl:Class rdf:about="#Perro">
  <rdfs:subClassOf rdf:resource="#Mamifero"/>
</owl:Class>

<owl:Class rdf:about="#Canario">
  <rdfs:subClassOf rdf:resource="#Ave"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#Fido">
  <rdf:type rdf:resource="#Perro"/>
  <puede rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ladrar</puede>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Tweety">
  <rdf:type rdf:resource="#Canario"/>
  <puede rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cantar</puede>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Twitter">
  <rdf:type rdf:resource="#Canario"/>
  <puede rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cantar</puede>
</owl:NamedIndividual>


</rdf:RDF>
